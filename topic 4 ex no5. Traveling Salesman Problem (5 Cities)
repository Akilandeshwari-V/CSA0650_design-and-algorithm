from itertools import permutations

d = [[0,10,15,20,25],
     [10,0,35,25,30],
     [15,35,0,30,20],
     [20,25,30,0,15],
     [25,30,20,15,0]]

m = 999

for p in permutations(range(1,5)):
    c = d[0][p[0]]

    for i in range(len(p)-1):
        c += d[p[i]][p[i+1]]

    c += d[p[-1]][0]

    m = min(m,c)

print(m)
